<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_auth_oauth_custom" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.auth.oauth.custom</field>
        <field name="model">res.config.settings</field>
        <!-- Chỉ kế thừa General Settings chuẩn -->
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>

        <field name="arch" type="xml">
            <!-- Chèn block mới vào trong sheet (anchor chắc chắn tồn tại) -->
            <xpath expr="//sheet" position="inside">
                <div class="app_settings_block"
                     data-key="auth_oauth_custom"
                     string="OAuth (Custom)">
                    <h2>OAuth (Custom)</h2>
                    <div class="o_settings_container">
                        <div class="row mt16">
                            <!-- Cột cấu hình Google -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="auth_oauth_custom_google_enabled"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="auth_oauth_custom_google_enabled"/>
                                    <div class="text-muted">
                                        Allow users to sign in with their Google account (custom flow).
                                    </div>

                                    <div class="mt16"
                                         attrs="{'invisible': [('auth_oauth_custom_google_enabled', '=', False)]}">
                                        <div class="row mt16">
                                            <label for="auth_oauth_custom_google_client_id"
                                                   string="Client ID:"
                                                   class="col-lg-3 o_light_label"/>
                                            <field name="auth_oauth_custom_google_client_id"
                                                   placeholder="e.g. 1234-xyz.apps.googleusercontent.com"/>
                                        </div>

                                        <div class="row mt16">
                                            <label for="server_uri_google"
                                                   string="Redirect URI:"
                                                   class="col-lg-3 o_light_label"/>
                                            <field name="server_uri_google" readonly="1"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Cột nút mở danh sách Provider -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <button type="action"
                                            name="%(auth_oauth_custom.action_oauth_provider)d"
                                            string="Configure OAuth Providers"
                                            class="btn btn-link"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
