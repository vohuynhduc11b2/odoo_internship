<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_payment_incident" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.payment.incident</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/div[@name='button_box']" position="inside">
                <button name="action_view_payment_incidents" type="object" class="oe_stat_button" icon="fa-exclamation-triangle">
                    <field name="payment_incident_count" string="Sự cố thanh toán" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="Sự cố thanh toán">
                    <group>
                        <button name="action_log_payment_incident" type="object" string="Ghi nhận sự cố" class="btn-primary"/>
                    </group>
                    <field name="payment_incident_ids" context="{'default_sale_order_id': id, 'default_scope': 'payment'}" mode="list,form">
                        <list decoration-danger="incident_type == 'error'" decoration-warning="incident_type == 'warning'">
                            <field name="incident_date"/>
                            <field name="title"/>
                            <field name="incident_type" widget="badge"/>
                            <field name="severity" widget="badge"/>
                            <field name="state" widget="badge"/>
                            <field name="category_id"/>
                            <field name="transaction_id"/>
                            <field name="auto_generated"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
