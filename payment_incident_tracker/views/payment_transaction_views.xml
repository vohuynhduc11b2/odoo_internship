<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_transaction_form_inherit_incident" model="ir.ui.view">
        <field name="name">payment.transaction.form.inherit.incident</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="inside">
                <div class="oe_button_box" name="oms_payment_incident_button_box">
                    <button name="action_view_payment_incidents" type="object" class="oe_stat_button" icon="fa-exclamation-triangle">
                        <field name="incident_count" string="Sự cố/Cảnh báo" widget="statinfo"/>
                    </button>
                </div>
                <group string="Theo dõi sự cố thanh toán">
                    <group>
                        <field name="open_incident_count" readonly="1"/>
                        <field name="incident_count" readonly="1"/>
                    </group>
                    <group>
                        <button name="action_log_payment_incident" type="object" string="Ghi nhận sự cố" class="btn-primary"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
