<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_oms_payment_incident_category_tree" model="ir.ui.view">
        <field name="name">oms.payment.incident.category.tree</field>
        <field name="model">oms.payment.incident.category</field>
        <field name="arch" type="xml">
            <list string="Danh mục sự cố thanh toán" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="scope"/>
                <field name="default_incident_type"/>
                <field name="default_severity"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_oms_payment_incident_category_form" model="ir.ui.view">
        <field name="name">oms.payment.incident.category.form</field>
        <field name="model">oms.payment.incident.category</field>
        <field name="arch" type="xml">
            <form string="Danh mục sự cố thanh toán">
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="scope"/>
                        </group>
                        <group>
                            <field name="default_incident_type"/>
                            <field name="default_severity"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mặc định">
                            <group>
                                <field name="default_root_cause"/>
                                <field name="default_prevention_action"/>
                                <field name="note"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_oms_payment_incident_log_list" model="ir.ui.view">
        <field name="name">oms.payment.incident.log.list</field>
        <field name="model">oms.payment.incident.log</field>
        <field name="arch" type="xml">
            <list string="Sự cố/Cảnh báo thanh toán"
                  decoration-danger="incident_type == 'error'"
                  decoration-warning="incident_type == 'warning'"
                  decoration-muted="state in ('resolved', 'closed')">
                <field name="name"/>
                <field name="incident_date"/>
                <field name="incident_period_label"/>
                <field name="title"/>
                <field name="incident_type" widget="badge"
                       decoration-danger="incident_type == 'error'"
                       decoration-warning="incident_type == 'warning'"/>
                <field name="severity" widget="badge"
                       decoration-info="severity == 'low'"
                       decoration-warning="severity in ('medium', 'high')"
                       decoration-danger="severity == 'critical'"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'open'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state in ('resolved', 'closed')"/>
                <field name="category_id"/>
                <field name="provider_id"/>
                <field name="sale_order_id"/>
                <field name="transaction_id"/>
                <field name="partner_id"/>
                <field name="responsible_id"/>
                <field name="auto_generated"/>
                <field name="is_repeat_issue"/>
            </list>
        </field>
    </record>

    <record id="view_oms_payment_incident_log_form" model="ir.ui.view">
        <field name="name">oms.payment.incident.log.form</field>
        <field name="model">oms.payment.incident.log</field>
        <field name="arch" type="xml">
            <form string="Sự cố/Cảnh báo thanh toán">
                <header>
                    <button name="action_mark_in_progress" type="object" string="Đang xử lý" class="btn-secondary" invisible="state != 'open'"/>
                    <button name="action_mark_resolved" type="object" string="Đã xử lý" class="btn-primary" invisible="state not in ('open', 'in_progress')"/>
                    <button name="action_mark_closed" type="object" string="Đóng" class="btn-secondary" invisible="state != 'resolved'"/>
                    <button name="action_reopen" type="object" string="Mở lại" class="btn-secondary" invisible="state not in ('resolved', 'closed')"/>
                    <field name="state" widget="statusbar" statusbar_visible="open,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_transaction" type="object" class="oe_stat_button" icon="fa-credit-card" invisible="not transaction_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Giao dịch</span>
                            </div>
                        </button>
                        <button name="action_open_sale_order" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="not sale_order_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Đơn hàng</span>
                            </div>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="title"/>
                            <field name="incident_date"/>
                            <field name="incident_period_label" readonly="1"/>
                            <field name="scope"/>
                            <field name="incident_type"/>
                            <field name="severity"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="transaction_id"/>
                            <field name="sale_order_id"/>
                            <field name="partner_id"/>
                            <field name="provider_id"/>
                            <field name="currency_id"/>
                            <field name="amount"/>
                            <field name="responsible_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Phân tích nguyên nhân">
                            <group>
                                <field name="symptom" placeholder="Mô tả hiện tượng xảy ra..."/>
                                <field name="root_cause" placeholder="Nguyên nhân gốc..."/>
                                <field name="prevention_action" placeholder="Cách phòng tránh để hạn chế lỗi lặp lại..."/>
                                <field name="correction_action" placeholder="Hướng xử lý/khắc phục..."/>
                                <field name="resolution_note" placeholder="Kết quả xử lý thực tế..."/>
                                <field name="technical_note" placeholder="Link log, endpoint callback, ghi chú kỹ thuật..."/>
                            </group>
                        </page>
                        <page string="Quản trị">
                            <group>
                                <field name="auto_generated"/>
                                <field name="is_repeat_issue"/>
                                <field name="repeat_reference"/>
                                <field name="active"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_oms_payment_incident_log_search" model="ir.ui.view">
        <field name="name">oms.payment.incident.log.search</field>
        <field name="model">oms.payment.incident.log</field>
        <field name="arch" type="xml">
            <search string="Tìm sự cố thanh toán">
                <field name="name"/>
                <field name="title"/>
                <field name="transaction_id"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="provider_id"/>
                <field name="category_id"/>
                <filter name="open" string="Đang mở" domain="[('state', 'in', ('open', 'in_progress'))]"/>
                <filter name="error" string="Lỗi" domain="[('incident_type', '=', 'error')]"/>
                <filter name="warning" string="Cảnh báo" domain="[('incident_type', '=', 'warning')]"/>
                <filter name="auto_generated" string="Tự động sinh" domain="[('auto_generated', '=', True)]"/>
                <filter name="repeat_issue" string="Lỗi lặp lại" domain="[('is_repeat_issue', '=', True)]"/>
                <filter name="q1_2026" string="Q1/2026" domain="[('incident_year', '=', 2026), ('incident_quarter', '=', '1')]"/>
                <separator/>
                <filter string="Nhóm theo danh mục" name="group_category" context="{'group_by': 'category_id'}"/>
                <filter string="Nhóm theo cổng thanh toán" name="group_provider" context="{'group_by': 'provider_id'}"/>
                <filter string="Nhóm theo mức độ" name="group_severity" context="{'group_by': 'severity'}"/>
                <filter string="Nhóm theo trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Nhóm theo quý" name="group_quarter" context="{'group_by': 'incident_period_label'}"/>
            </search>
        </field>
    </record>

    <record id="view_oms_payment_incident_log_graph" model="ir.ui.view">
        <field name="name">oms.payment.incident.log.graph</field>
        <field name="model">oms.payment.incident.log</field>
        <field name="arch" type="xml">
            <graph string="Biểu đồ sự cố thanh toán" type="bar">
                <field name="category_id" type="row"/>
                <field name="id" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_oms_payment_incident_log_pivot" model="ir.ui.view">
        <field name="name">oms.payment.incident.log.pivot</field>
        <field name="model">oms.payment.incident.log</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích sự cố thanh toán">
                <field name="category_id" type="row"/>
                <field name="severity" type="col"/>
                <field name="id" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_oms_payment_incident_log" model="ir.actions.act_window">
        <field name="name">Sự cố/Cảnh báo thanh toán</field>
        <field name="res_model">oms.payment.incident.log</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="search_view_id" ref="view_oms_payment_incident_log_search"/>
        <field name="context">{'search_default_open': 1}</field>
    </record>

    <record id="action_oms_payment_incident_category" model="ir.actions.act_window">
        <field name="name">Danh mục sự cố thanh toán</field>
        <field name="res_model">oms.payment.incident.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
