<odoo>
  <record id="view_oms_promotion_multi_apply_wizard_form" model="ir.ui.view">
    <field name="name">promotion.multi.apply.wizard.form</field>
    <field name="model">promotion.multi.apply.wizard</field>
    <field name="arch" type="xml">
      <form string="Chọn khuyến mãi và combo quà tặng">
        <sheet>
          <field name="line_ids">
            <list editable="bottom" create="false" delete="false"
                  decoration-danger="promotion_has_combo and checked and not gift_combo_id">
              <field name="promotion_id" invisible="1"/>
              <field name="promotion_has_combo" invisible="1"/>
              <field name="checked"/>
              <field name="promotion_id" readonly="1" options="{'no_open': True}"/>
              <field name="gift_combo_id"
                     options="{'no_create': True}"
                     attrs="{
                       'readonly': [('checked','=', False)],
                       'required': [('promotion_has_combo','=', True), ('checked','=', True)]
                     }"/>
            </list>
          </field>

          <!-- Đổi LABEL thành div có class o_form_label -->
          <div class="o_form_label text-warning">
            Lưu ý: Với khuyến mãi có combo quà tặng, bạn bắt buộc chọn Combo trước khi áp dụng.
          </div>
        </sheet>
        <footer>
          <button string="Áp dụng" type="object" name="action_apply" class="btn-primary"/>
          <button string="Đóng" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_promotion_multi_apply_wizard" model="ir.actions.act_window">
    <field name="name">Chọn khuyến mãi</field>
    <field name="res_model">promotion.multi.apply.wizard</field>
    <field name="view_mode">form</field>
    <field name="view_id" ref="view_oms_promotion_multi_apply_wizard_form"/>
    <field name="target">new</field>
  </record>
</odoo>
