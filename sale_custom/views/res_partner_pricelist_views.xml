<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tab Bảng giá áp dụng trên form khách hàng -->
    <record id="view_res_partner_form_pricelist" model="ir.ui.view">
        <field name="name">res.partner.form.pricelist</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="pricelists" string="Bảng giá áp dụng">
                    <field name="customer_pricelist_ids"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
