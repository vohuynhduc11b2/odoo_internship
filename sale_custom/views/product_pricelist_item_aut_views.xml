<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend product.pricelist.item tree view để hiển thị Khung giá OMS và Max OMS -->
    <record id="view_product_pricelist_item_aut_tree" model="ir.ui.view">
        <field name="name">product.pricelist.item.aut.tree</field>
        <field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_tree_view"/>
        <field name="priority" eval="90"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price']" position="after">
                <field name="oms_price_frame_id" optional="show" string="Khung giá OMS"/>
                <field name="oms_category_name" optional="show" string="Category Name"/>
                <field name="oms_max_quantity" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Extend product.pricelist.item form view để hiển thị Khung giá OMS và Max OMS -->
    <record id="view_product_pricelist_item_aut_form" model="ir.ui.view">
        <field name="name">product.pricelist.item.aut.form</field>
        <field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_form_view"/>
        <field name="priority" eval="90"/>
        <field name="arch" type="xml">
            <!-- Thêm field Khung giá OMS - tìm cách insert tốt nhất -->
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="oms_price_frame_id" string="Khung giá OMS"/>
                <field name="oms_category_name" string="Category Name"/>
                <button name="action_sync_price_frame" type="object" string="Sync khung giá" icon="fa-refresh" class="oe_inline" help="Thực hiện sync lại khung giá OMS cho dòng này"/>
            </xpath>
            <!-- Fallback - nếu product_id không tìm thấy, insert sau date_start -->
            <xpath expr="//field[@name='date_start']" position="after">
                <field name="oms_price_frame_id" string="Khung giá OMS" optional="show"/>
                <field name="oms_category_name" string="Category Name" optional="show"/>
                <field name="oms_max_quantity" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
