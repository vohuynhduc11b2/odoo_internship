<odoo>
  <record id="view_oms_inventory_list" model="ir.ui.view">
    <field name="name">oms.inventory.list</field>
    <field name="model">oms.inventory</field>
    <field name="arch" type="xml">
      <list>
        <field name="item_code"/>
        <field name="product_id"/>
        <field name="whs_code"/>
        <field name="whs_name"/>
        <field name="on_hand"/>
        <field name="is_commited"/>
        <field name="on_order"/>
        <field name="u_available"/>
      </list>
    </field>
  </record>

  <record id="view_oms_inventory_search" model="ir.ui.view">
    <field name="name">oms.inventory.search</field>
    <field name="model">oms.inventory</field>
    <field name="arch" type="xml">
      <search>
        <field name="item_code"/>
        <field name="whs_code"/>
        <field name="whs_name"/>
        <filter name="available_gt0" string="Khả dụng > 0" domain="[('u_available','&gt;',0)]"/>
      </search>
    </field>
  </record>

  <record id="action_oms_inventory" model="ir.actions.act_window">
    <field name="name">OMS Inventory</field>
    <field name="res_model">oms.inventory</field>
    <field name="view_mode">list</field>
  </record>

</odoo>
