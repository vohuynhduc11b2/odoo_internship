<odoo>
    <record id="view_oms_special_price_list" model="ir.ui.view">
        <field name="name">oms.special.price.list</field>
        <field name="model">oms.special.price</field>
        <field name="arch" type="xml">
            <list>
                <field name="customer_id"/>
                <field name="business_unit"/>
                <field name="level_code"/>
                <field name="valid_from"/>
                <field name="valid_to"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_oms_special_price_form" model="ir.ui.view">
        <field name="name">oms.special.price.form</field>
        <field name="model">oms.special.price</field>
        <field name="arch" type="xml">
            <form string="Giá đặc biệt KH OMS">
                <header>
                    <button name="%(action_oms_special_price_import_export)d"
                        type="action"
                        string="Export Excel"
                        class="btn-primary"/>
                </header>
                <group>
                    <field name="customer_id"/>
                    <field name="business_unit"/>
                    <field name="level_code"/>
                    <field name="valid_from"/>
                    <field name="valid_to"/>
                    <field name="note"/>
                </group>
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="item_id"/>
                        <field name="item_code" readonly="1"/>
                        <field name="special_price"/>
                        <field name="valid_from"/>
                        <field name="valid_to"/>
                        <field name="note"/>
                    </list>
                </field>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_oms_special_price" model="ir.actions.act_window">
        <field name="name">Giá đặc biệt KH OMS</field>
        <field name="res_model">oms.special.price</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Thêm giá đặc biệt cho từng khách hàng và từng sản phẩm.<br/>
                Hệ thống sẽ ưu tiên giá này khi lập báo giá/bán hàng.
            </p>
        </field>
    </record>
</odoo>
