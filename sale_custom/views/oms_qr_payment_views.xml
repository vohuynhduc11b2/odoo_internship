<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view wizard tạo QR -->
    <record id="view_oms_qr_payment_wizard_form" model="ir.ui.view">
        <field name="name">oms.qr.payment.wizard.form</field>
        <field name="model">oms.qr.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Tạo QR thanh toán Vietcombank">
                <group>
                    <group>
                        <field name="partner_id"/>
                        <field name="amount"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="business_area"/>
                        <field name="is_deposit"/>
                        <field name="description" readonly="1"/>
                    </group>
                    <group>
                        <field name="bank_name" readonly="1"/>
                        <field name="bank_account" readonly="1"/>
                        <field name="sepay_qr_url" readonly="1" widget="url"/>
                    </group>
                </group>

                <separator string="HƯỚNG DẪN" colspan="2"/>
                <label class="o_form_label"
                       for="partner_id"
                       string="Nhấn &apos;Tải ảnh QR&apos; để tải file QR (PNG) về máy. Ảnh QR dùng từ Sepay."
                       colspan="2"/>

                <footer>
                    <button string="Tải ảnh QR"
                            name="action_download_qr"
                            type="object"
                            class="btn-primary"/>
                    <button string="Đóng"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action mở wizard từ menu -->
    <record id="action_oms_qr_payment_wizard" model="ir.actions.act_window">
        <field name="name">Tạo QR thanh toán</field>
        <field name="res_model">oms.qr.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_oms_qr_payment_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>
