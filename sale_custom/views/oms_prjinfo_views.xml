<odoo>
    <record id="view_oms_prjinfo_tree" model="ir.ui.view">
        <field name="name">oms.prjinfo.list</field>
        <field name="model">oms.prjinfo</field>
        <field name="arch" type="xml">
            <list>
                <field name="prj_code"/>
                <field name="name"/>
                <field name="card_name"/>
                <field name="u_category"/>
                <field name="ngay_tao"/>
                <field name="ngay_cap_nhat"/>
            </list>
        </field>
    </record>

    <record id="view_oms_prjinfo_form" model="ir.ui.view">
        <field name="name">oms.prjinfo.form</field>
        <field name="model">oms.prjinfo</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="prj_code"/>
                    <field name="prj_name"/>
                    <field name="u_card_code"/>
                    <field name="card_name"/>
                    <field name="u_category"/>
                    <field name="u_subcate"/>
                    <field name="u_appendix_amount"/>
                    <field name="u_mkt_amount"/>
                    <field name="nv_tao"/>
                    <field name="nv_cap_nhat"/>
                    <field name="ngay_tao"/>
                    <field name="ngay_cap_nhat"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_oms_prjinfo" model="ir.actions.act_window">
        <field name="name">Dự án OMS</field>
        <field name="res_model">oms.prjinfo</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
