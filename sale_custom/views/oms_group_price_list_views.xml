<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Search -->
  <record id="view_oms_group_price_list_search" model="ir.ui.view">
    <field name="name">oms.group.price.list.search</field>
    <field name="model">oms.group.price.list</field>
    <field name="arch" type="xml">
      <search string="Tìm bảng giá nhóm">
        <field name="name"/>
        <filter string="Đang hiệu lực" name="flt_valid"
                domain="['|', ('from_date','=',False), ('from_date','&lt;=', context_today()),
                         '|', ('to_date','=',False), ('to_date','&gt;=', context_today())]"/>
      </search>
    </field>
  </record>

  <!-- Header list -->
  <record id="view_oms_group_price_list_list" model="ir.ui.view">
    <field name="name">oms.group.price.list.list</field>
    <field name="model">oms.group.price.list</field>
    <field name="arch" type="xml">
      <list string="Bảng giá theo Nhóm SP" default_order="id desc">
        <field name="name"/>
        <field name="from_date"/>
        <field name="to_date"/>
        <field name="note"/>
      </list>
    </field>
  </record>

  <!-- Line list (inline) -->
  <record id="view_oms_group_price_list_line_list_simple" model="ir.ui.view">
    <field name="name">oms.group.price.list.line.list.simple</field>
    <field name="model">oms.group.price.list.line</field>
    <field name="arch" type="xml">
      <list editable="bottom" decoration-muted="not active" default_order="sequence, id">
        <field name="active"/>
        <!-- 👇 hiển thị Độ ưu tiên (sequence) ngay trên list -->
        <field name="sequence" string="Độ ưu tiên"/>
        <field name="product_group_ids" widget="many2many_tags"
               options="{'no_create_edit': True}"/>
        <field name="partner_scope" widget="radio"/>
        <!-- 👇 chỉ khách hàng + context tìm đúng KH -->
        <field name="partner_ids" widget="many2many_tags"
               context="{'res_partner_search_mode':'customer'}"
               placeholder="Chọn khách hàng (nếu cần)"/>        
        <field name="extra_amount"/>  
        <field name="from_date" optional="hide"/>
        <field name="to_date" optional="hide"/>
      </list>
    </field>
  </record>
  <!-- Line form -->
  <record id="view_oms_group_price_list_line_form_simple" model="ir.ui.view">
    <field name="name">oms.group.price.list.line.form.simple</field>
    <field name="model">oms.group.price.list.line</field>
    <field name="arch" type="xml">
      <form string="Dòng bảng giá nhóm">
        <sheet>
          <group>
            <group string="Thông tin">
              <field name="active"/>
              <field name="sequence"/>
              <field name="pricelist_id" invisible="1" nolabel="1" readonly="1"/>
              <field name="manual_from_date" invisible="1"/>
              <field name="manual_to_date" invisible="1"/>
              <field name="from_date"/>
              <field name="to_date"/>
            </group>
            <group string="Giá">
              <field name="extra_amount" required="1"
                     placeholder="VD: 100000"
                     help="Cộng thêm vào đơn giá (chỉ số dương)."/>
              <field name="currency_id" options="{'no_create': True}"/>
            </group>
          </group>

          <group string="Áp dụng cho">
            <group>
              <field name="product_group_ids" widget="many2many_tags" required="1"/>
            </group>
            <group>
              <field name="partner_scope" widget="radio"/>
              <field name="partner_ids" widget="many2many_tags"/>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Header form -->
  <record id="view_oms_group_price_list_form" model="ir.ui.view">
    <field name="name">oms.group.price.list.form</field>
    <field name="model">oms.group.price.list</field>
    <field name="arch" type="xml">
      <form string="Bảng giá theo Nhóm SP">
        <sheet>
          <group>
            <field name="name"/>
            <field name="note"/>
            <field name="from_date"/>
            <field name="to_date"/>
          </group>
          <group string="Dòng điều chỉnh">
            <field name="line_ids" mode="list,form"/>
          </group>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <!-- Action + Menu -->
  <record id="action_oms_group_price_list" model="ir.actions.act_window">
    <field name="name">Bảng giá theo Nhóm SP</field>
    <field name="res_model">oms.group.price.list</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
