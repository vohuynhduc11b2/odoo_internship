<odoo>
    <record id="view_oms_taxgroup_form" model="ir.ui.view">
        <field name="name">oms.taxgroup.form</field>
        <field name="model">oms.taxgroup</field>
        <field name="arch" type="xml">
            <form string="Tax Group OMS">
                <group>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="rate"/>
                    <field name="active"/>
                </group>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_oms_taxgroup_list" model="ir.ui.view">
        <field name="name">oms.taxgroup.list</field>
        <field name="model">oms.taxgroup</field>
        <field name="arch" type="xml">
            <list string="Tax Groups">
                <field name="code"/>
                <field name="name"/>
                <field name="rate"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="action_oms_taxgroup" model="ir.actions.act_window">
        <field name="name">Tax Groups OMS</field>
        <field name="res_model">oms.taxgroup</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
