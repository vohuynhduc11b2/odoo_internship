<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action -->
    <record id="action_oms_customer_pricelist" model="ir.actions.act_window">
        <field name="name">Gán bảng giá khách hàng</field>
        <field name="res_model">oms.customer.pricelist</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_oms_customer_pricelist_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Gán bảng giá cho khách hàng.
            </p>
            <p>
                Mỗi dòng thể hiện một bảng giá đang được áp dụng cho một khách hàng.
                Một khách hàng có thể có nhiều bảng giá, nhưng chỉ một bảng giá mặc định.
            </p>
        </field>
    </record>

    <!-- List View -->
    <record id="view_oms_customer_pricelist_list" model="ir.ui.view">
        <field name="name">oms.customer.pricelist.list</field>
        <field name="model">oms.customer.pricelist</field>
        <field name="priority" eval="10"/>
        <field name="arch" type="xml">
            <list create="true" edit="true" delete="true">
                <field name="partner_id" optional="show"/>
                <field name="partner_card_code" optional="show"/>
                <field name="pricelist_id" optional="show"/>
                <field name="price_frame_name" optional="show"/>
                <field name="is_default" optional="show" widget="boolean_toggle"/>
                <field name="priority" optional="show"/>
                <field name="valid_from" optional="show"/>
                <field name="valid_to" optional="show"/>
                <field name="state" optional="show" widget="badge"
                    decoration-success="state == 'active'"
                    decoration-warning="state == 'draft'"
                    decoration-muted="state in ('expired', 'cancelled')"/>
                <field name="is_valid" optional="hide"/>
                <field name="note" optional="hide"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_oms_customer_pricelist_form" model="ir.ui.view">
        <field name="name">oms.customer.pricelist.form</field>
        <field name="model">oms.customer.pricelist</field>
        <field name="priority" eval="10"/>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Kích hoạt" type="object"
                        invisible="state != 'draft'"
                        class="btn-success" icon="fa-check"/>
                    <button name="action_set_default" string="Đặt mặc định" type="object"
                        invisible="state != 'active' or is_default == True"
                        class="btn-primary" icon="fa-star"/>
                    <button name="action_expire" string="Hết hiệu lực" type="object"
                        invisible="state != 'active'"
                        class="btn-warning" icon="fa-clock-o"/>
                    <button name="action_cancel" string="Hủy" type="object"
                        invisible="state in ('expired', 'cancelled')"
                        class="btn-danger" icon="fa-times"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,active,expired"
                        invisible="state in ('cancelled',)"/>
                </header>
                <sheet>
                    <group col="1">
                        <group string="Thông tin khách hàng">
                            <field name="partner_id" options="{'no_create_edit': True}"/>
                            <field name="partner_card_code" readonly="1"/>
                            <field name="partner_name" readonly="1"/>
                        </group>
                        <group string="Thông tin bảng giá">
                            <field name="pricelist_id" options="{'no_create_edit': True}"/>
                            <field name="pricelist_name" readonly="1" invisible="1"/>
                            <field name="price_frame_id" readonly="1" options="{'no_create_edit': True}"/>
                            <field name="price_frame_name" readonly="1"/>
                        </group>
                        <group string="Cấu hình áp dụng">
                            <field name="is_default"/>
                            <field name="priority"/>
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                        </group>
                        <group string="Thông tin bổ sung">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                            <field name="is_valid" readonly="1"/>
                            <field name="note" placeholder="Ghi chú về chính sách giá..."/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_oms_customer_pricelist_search" model="ir.ui.view">
        <field name="name">oms.customer.pricelist.search</field>
        <field name="model">oms.customer.pricelist</field>
        <field name="priority" eval="10"/>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="partner_card_code"/>
                <field name="pricelist_id"/>
                <field name="price_frame_name"/>
                <field name="note"/>
                
                <separator/>
                
                <filter string="Đang áp dụng" name="filter_active"
                    domain="[('state', '=', 'active'), ('active', '=', True)]"/>
                <filter string="Mặc định" name="filter_default"
                    domain="[('is_default', '=', True), ('state', '=', 'active')]"/>
                <filter string="Hết hiệu lực" name="filter_expired"
                    domain="[('state', '=', 'expired')]"/>
                <filter string="Đã hủy" name="filter_cancelled"
                    domain="[('state', '=', 'cancelled')]"/>
                <filter string="Còn hiệu lực" name="filter_valid"
                    domain="[('is_valid', '=', True)]"/>
                
                <separator/>
                
                <filter string="Công ty" name="group_company" context="{'group_by': 'company_id'}"
                    groups="base.group_multi_company"/>
                <filter string="Khách hàng" name="group_partner" context="{'group_by': 'partner_id'}"/>
                <filter string="Bảng giá" name="group_pricelist" context="{'group_by': 'pricelist_id'}"/>
                <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Khung giá" name="group_frame" context="{'group_by': 'price_frame_id'}"/>
                
                <searchpanel>
                    <field name="state" icon="fa fa-filter" select="multi"
                        string="Trạng thái"
                        available_values="draft,active,expired,cancelled"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_oms_customer_pricelist_pivot" model="ir.ui.view">
        <field name="name">oms.customer.pricelist.pivot</field>
        <field name="model">oms.customer.pricelist</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="partner_id" type="row"/>
                <field name="pricelist_id" type="col"/>
                <field name="state" type="col"/>
                <field name="is_default" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_oms_customer_pricelist_graph" model="ir.ui.view">
        <field name="name">oms.customer.pricelist.graph</field>
        <field name="model">oms.customer.pricelist</field>
        <field name="arch" type="xml">
            <graph type="pie">
                <field name="state"/>
                <field name="partner_id" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Activity View -->
    <record id="view_oms_customer_pricelist_activity" model="ir.ui.view">
        <field name="name">oms.customer.pricelist.activity</field>
        <field name="model">oms.customer.pricelist</field>
        <field name="arch" type="xml">
            <activity string="Gán bảng giá">
                <field name="partner_id"/>
                <templates>
                    <div t-name="activity-box">
                        <field name="pricelist_id" display="full"/>
                        <div class="o_activity_name_cell_links">
                            <field name="state" widget="badge"/>
                        </div>
                    </div>
                </templates>
            </activity>
        </field>
    </record>
</odoo>
