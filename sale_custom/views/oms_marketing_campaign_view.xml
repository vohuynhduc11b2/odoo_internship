<odoo>
    <!-- List View -->
    <record id="view_oms_marketing_campaign_list" model="ir.ui.view">
        <field name="name">oms.marketing.campaign.list</field>
        <field name="model">oms.marketing.campaign</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="u_active"/>
                <field name="canceled"/>
                <field name="u_has_price_list"/>
                <field name="u_is_clear_stock"/>
                <field name="u_from_date"/>
                <field name="u_to_date"/>
                <field name="update_date_api"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_oms_marketing_campaign_form" model="ir.ui.view">
        <field name="name">oms.marketing.campaign.form</field>
        <field name="model">oms.marketing.campaign</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="u_active"/>
                        <field name="canceled"/>
                        <field name="u_has_price_list"/>
                        <field name="u_is_clear_stock"/>
                        <field name="u_from_date"/>
                        <field name="u_to_date"/>
                        <field name="doc_entry"/>
                        <field name="object"/>
                        <field name="log_inst"/>
                        <field name="user_sign"/>
                        <field name="transfered"/>
                        <field name="data_source"/>
                        <field name="create_date_api"/>
                        <field name="update_date_api"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_oms_marketing_campaign" model="ir.actions.act_window">
        <field name="name">Chương trình Marketing</field>
        <field name="res_model">oms.marketing.campaign</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
