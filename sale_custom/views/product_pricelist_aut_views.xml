<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend form view của product.pricelist để thêm fields AUT -->
    <!-- List view đã được extend trong oms_aut_pricelist_views.xml (priority 90) -->
    <record id="view_product_pricelist_form_aut" model="ir.ui.view">
        <field name="name">product.pricelist.form.aut</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="priority" eval="20"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_be_price_frame_id" options="{'no_create_edit': True}" string="Khung giá OMS"/>
                <field name="x_category_id" options="{'no_create_edit': True}" string="Danh mục sản phẩm"/>
                <field name="x_category_name" readonly="1" string="Tên danh mục"/>
                <field name="x_frame_publish_pricelist_ids" widget="many2many_tags" options="{'no_create_edit': True}" string="Bảng giá lấy" optional="show"/>
                <field name="x_frame_max_qty" string="Max Quantity" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
