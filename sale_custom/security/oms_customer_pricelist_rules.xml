<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security rules cho oms.customer.pricelist -->
    
    <!-- Sales user - chỉ xem những khách hàng thuộc đội họ của mình -->
    <record id="oms_customer_pricelist_rule_sales_user" model="ir.rule">
        <field name="name">OMS Customer Pricelist - Sales User</field>
        <field name="model_id" ref="model_oms_customer_pricelist"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
        <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
    </record>

    <!-- Sales Manager - có thể tạo/sửa bảng giá cho khách hàng -->
    <record id="oms_customer_pricelist_rule_sales_manager" model="ir.rule">
        <field name="name">OMS Customer Pricelist - Sales Manager</field>
        <field name="model_id" ref="model_oms_customer_pricelist"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
        <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
    </record>

    <!-- Admin - full access -->
    <record id="oms_customer_pricelist_rule_admin" model="ir.rule">
        <field name="name">OMS Customer Pricelist - Admin</field>
        <field name="model_id" ref="model_oms_customer_pricelist"/>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
