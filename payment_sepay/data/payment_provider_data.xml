<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="payment_provider_sepay" model="payment.provider">
        <field name="name">SePay</field>
        <field name="code">sepay</field>
        <field name="state">disabled</field>

        <field name="company_id" ref="base.main_company"/>

        <field name="allow_tokenization">False</field>
        <field name="allow_express_checkout">False</field>
    </record>

    <record id="payment_method_sepay" model="payment.method">
        <field name="name">SePay</field>
        <field name="code">sepay</field>
        <field name="provider_ids" eval="[(6,0,[ref('payment_provider_sepay')])]"/>
    </record>

</odoo>
