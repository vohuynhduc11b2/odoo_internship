<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="oms_checkout_layout_grid_cols" name="OMS Checkout Layout Grid Columns" inherit_id="website_sale_custom.checkout_layout" priority="99999">
        <xpath expr="//div[@id='wrap']" position="attributes">
            <attribute name="class" add="oms_checkout_page_wrap" separator=" "/>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion']" position="attributes">
            <attribute name="class">o_wsale_accordion accordion sticky-lg-top col-12 col-lg-4 col-xl-4 order-lg-2 rounded</attribute>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion_item']" position="replace">
            <div id="o_wsale_total_accordion_item" class="accordion-item p-lg-4 border-0 oms_checkout_summary_compact">
                <div class="oms_checkout_summary_head">
                    <div>
                        <b>Tóm tắt đơn hàng</b>
                        <span class="oms_checkout_summary_meta">
                            <span t-out="str(website_sale_order.cart_quantity)"/>
                            &amp;nbsp;mặt hàng&amp;nbsp;·&amp;nbsp;
                            <span id="amount_total_summary"
                                  class="monetary_field"
                                  t-field="website_sale_order.amount_total"
                                  t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                        </span>
                    </div>
                    <button t-if="website_sale_order and website_sale_order.website_order_line"
                            type="button"
                            class="oms_checkout_summary_detail_btn"
                            data-bs-toggle="modal"
                            data-bs-target="#oms_checkout_order_detail_modal">
                        Xem chi tiết
                    </button>
                </div>
                <div name="cart_summary_info" t-if="not website_sale_order or not website_sale_order.website_order_line" class="alert alert-info">
                    Your cart is empty!
                </div>
                <div t-if="website_sale_order and website_sale_order.website_order_line" class="oms_checkout_summary_preview">
                    <t t-set="preview_lines" t-value="website_sale_order.website_order_line[:2]"/>
                    <div t-foreach="preview_lines" t-as="line" class="oms_checkout_summary_preview_line">
                        <span class="oms_checkout_summary_preview_qty"><t t-out="int(line.product_uom_qty)"/>x</span>
                        <span class="oms_checkout_summary_preview_name" t-out="line.name_short"/>
                        <span class="oms_checkout_summary_preview_price">
                            <t t-call="website_sale_custom.cart_product_price"/>
                        </span>
                    </div>
                    <div t-if="len(website_sale_order.website_order_line) &gt; 2" class="oms_checkout_summary_more">
                        + <t t-out="len(website_sale_order.website_order_line) - 2"/> mặt hàng khác
                    </div>
                </div>
                <t t-call="website_sale_custom.total">
                    <t t-set="_cart_total_classes" t-valuef="border-top pt-3"/>
                </t>
                <div t-if="show_navigation_button" class="o_cta_navigation_container position-absolute position-lg-static start-0 bottom-0 col-12">
                    <t t-call="website_sale_custom.navigation_buttons"/>
                </div>
            </div>
            <div t-if="website_sale_order and website_sale_order.website_order_line"
                 class="modal fade oms_checkout_order_detail_modal"
                 id="oms_checkout_order_detail_modal"
                 tabindex="-1"
                 aria-labelledby="oms_checkout_order_detail_title"
                 aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <div>
                                <h5 class="modal-title" id="oms_checkout_order_detail_title">Chi tiết đơn hàng</h5>
                                <p class="mb-0">
                                    <span t-out="str(website_sale_order.cart_quantity)"/>
                                    &amp;nbsp;mặt hàng&amp;nbsp;·&amp;nbsp;
                                    <span class="monetary_field"
                                          t-field="website_sale_order.amount_total"
                                          t-options='{"widget": "monetary", "display_currency": website_sale_order.currency_id}'/>
                                </p>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"/>
                        </div>
                        <div class="modal-body">
                            <div class="oms_checkout_order_lines">
                                <div t-foreach="website_sale_order.website_order_line" t-as="line" class="oms_checkout_order_line">
                                    <t t-if="line.product_id">
                                        <div class="oms_checkout_order_line_img">
                                            <span t-if="line._is_not_sellable_line() and line.product_id.image_128">
                                                <img t-att-src="image_data_uri(line.product_id.image_128)" class="o_image_64_max img rounded" t-att-alt="line.name_short"/>
                                            </span>
                                            <span t-else=""
                                                  t-field="line.product_id.image_128"
                                                  t-options="{'widget': 'image', 'qweb_img_responsive': False, 'class': 'o_image_64_max rounded'}"/>
                                        </div>
                                        <div class="oms_checkout_order_line_info">
                                            <h6>
                                                <span><t t-out="int(line.product_uom_qty)"/> x</span>
                                                <t t-out="line.name_short"/>
                                            </h6>
                                            <t t-set="gift_lines"
                                               t-value="line._get_linked_lines().filtered(lambda l: (getattr(l, 'is_gift', False) or getattr(l, 'line_kind', '') == 'KM' or getattr(l, 'U_isDiscount', '') == 'KM') and l.product_id and not l.display_type)"/>
                                            <div t-if="gift_lines" class="small text-muted">
                                                <div t-foreach="gift_lines" t-as="gift_line">
                                                    <span class="text-success fw-semibold">Gift:</span>
                                                    <span t-out="gift_line.name_short or gift_line.product_id.display_name"/>
                                                    <span>x <t t-out="gift_line._get_displayed_quantity()"/></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="oms_checkout_order_line_price">
                                            <t t-call="website_sale_custom.cart_product_price"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <div class="oms_checkout_modal_total w-100">
                                <t t-call="website_sale_custom.total">
                                    <t t-set="_cart_total_classes" t-valuef="border-top pt-3"/>
                                    <t t-set="hide_promotions" t-value="True"/>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
        <xpath expr="//div[contains(@t-attf-class, 'oe_cart')]" position="attributes">
            <attribute name="t-attf-class">oe_cart col-12 col-lg-8 col-xl-8</attribute>
        </xpath>
    </template>
</odoo>
