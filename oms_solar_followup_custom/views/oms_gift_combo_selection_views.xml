<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_oms_gift_combo_selection_tree" model="ir.ui.view">
        <field name="name">oms.solar.gift.combo.selection.tree</field>
        <field name="model">oms.solar.gift.combo.selection</field>
        <field name="arch" type="xml">
            <list>
                <field name="order_id"/>
                <field name="line_id"/>
                <field name="promotion_id"/>
                <field name="combo_id"/>
                <field name="purchased_qty"/>
                <field name="allowed_qty"/>
                <field name="selected_qty"/>
                <field name="main_product_price"/>
            </list>
        </field>
    </record>

    <record id="view_oms_gift_combo_selection_form" model="ir.ui.view">
        <field name="name">oms.solar.gift.combo.selection.form</field>
        <field name="model">oms.solar.gift.combo.selection</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="order_id" readonly="1"/>
                            <field name="line_id" readonly="1"/>
                            <field name="promotion_id" readonly="1"/>
                            <field name="combo_id"/>
                        </group>
                        <group>
                            <field name="purchased_qty" readonly="1"/>
                            <field name="allowed_qty" readonly="1"/>
                            <field name="selected_qty"/>
                            <field name="main_product_price" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_oms_gift_combo_selection" model="ir.actions.act_window">
        <field name="name">Lựa chọn combo quà</field>
        <field name="res_model">oms.solar.gift.combo.selection</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_oms_gift_combo_selection_tree"/>
    </record>
</odoo>
