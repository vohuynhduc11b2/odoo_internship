<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_picking_oms_tree" model="ir.ui.view">
        <field name="name">stock.picking.oms.tree</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="origin"/>
                <field name="state"/>
                <field name="oms_lock_flag"/>
                <field name="oms_lock_note"/>
                <field name="oms_expected_delivery_date"/>
            </list>
        </field>
    </record>

    <record id="view_stock_picking_oms_form" model="ir.ui.view">
        <field name="name">stock.picking.oms.form</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="origin" readonly="1"/>
                        <field name="state" readonly="1"/>
                    </group>
                    <group string="Thông tin lock OMS">
                        <field name="oms_lock_flag"/>
                        <field name="oms_lock_note"/>
                        <field name="oms_expected_delivery_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_stock_picking_oms_followup" model="ir.actions.act_window">
        <field name="name">Phiếu xuất kho / lock OMS</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_stock_picking_oms_tree"/>
    </record>
</odoo>
