<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_category_oms_tree" model="ir.ui.view">
        <field name="name">product.category.oms.tree</field>
        <field name="model">product.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="oms_low_stock_warning_enabled"/>
                <field name="oms_low_stock_threshold"/>
                <field name="oms_low_stock_warning_message"/>
            </list>
        </field>
    </record>

    <record id="view_product_category_oms_form" model="ir.ui.view">
        <field name="name">product.category.oms.form</field>
        <field name="model">product.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                    </group>
                    <group string="Cảnh báo tồn kho OMS">
                        <field name="oms_low_stock_warning_enabled"/>
                        <field name="oms_low_stock_threshold"/>
                        <field name="oms_low_stock_warning_message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_category_oms" model="ir.actions.act_window">
        <field name="name">Nhóm sản phẩm cảnh báo tồn kho</field>
        <field name="res_model">product.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
