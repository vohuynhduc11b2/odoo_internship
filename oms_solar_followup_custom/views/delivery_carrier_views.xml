<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_carrier_form_oms_solar_followup" model="ir.ui.view">
        <field name="name">delivery.carrier.form.oms.solar.followup</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="website_sale_custom.view_delivery_carrier_form_website_delivery"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='carrier_description']" position="after">
                <field name="oms_is_outstation"/>
                <field name="oms_customer_pay_shipping_text" invisible="not oms_is_outstation"/>
            </xpath>
        </field>
    </record>

    <record id="view_delivery_carrier_tree_oms_solar_followup" model="ir.ui.view">
        <field name="name">delivery.carrier.tree.oms.solar.followup</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='delivery_type']" position="after">
                <field name="oms_is_outstation" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
